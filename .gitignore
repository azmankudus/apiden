# Exclude all files and directories by default
/*

# Allow specific files in the root
!/.gitignore
!/README.md
!/REQUIREMENTS.md
!/LICENSE
!/build.gradle.kts
!/settings.gradle.kts
!/gradle.properties
!/gradlew
!/gradlew.bat
!/.editorconfig

# Allow specific directories and their contents
!/gradle/
!/gradle/**
!/src/
!/src/**
!/.agent/
!/.agent/**
!/docs/
!/docs/**

# Explicitly exclude build and IDE artifacts
.gradle/
build/
.idea/
*.iml
.DS_Store
